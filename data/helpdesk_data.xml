<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">
    <!-- Sección de Equipos -->
    <record id="internal_helpdesk_team" model="helpdesk.ticket.team">
        <field name="name">Equipo de Soporte Interno</field>
        <field name="active">True</field>
    </record>

    <record id="external_helpdesk_team" model="helpdesk.ticket.team">
        <field name="name">Equipo de Soporte Externo</field>
        <field name="active">True</field>
    </record>

    <!-- Plantilla de Email Básica -->
    <record id="ticket_assignment_email_template" model="mail.template">
        <field name="name">Asignación de Ticket de Mesa de Ayuda</field>
        <field name="model_id" ref="helpdesk_mgmt.model_helpdesk_ticket" />
        <field name="subject">Nuevo Ticket: {{object.name}}</field>
        <field name="email_to">{{object.team_id.user_id.email}}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html"><![CDATA[
<p>Hola {{object.team_id.user_id.name}},</p>
<p>Se te ha asignado un nuevo ticket de mesa de ayuda:</p>
<ul>
    <li><strong>Número de Ticket:</strong> {{object.name}}</li>
    <li><strong>Cliente:</strong> {{object.partner_id.name or 'Usuario Invitado'}}</li>
    <li><strong>Email:</strong> {{object.partner_email or (object.partner_id.email if object.partner_id else 'Sin email')}}</li>
    <li><strong>Equipo:</strong> {{object.team_id.name}}</li>
</ul>
<p><a href="{{object.get_base_url()}}/web#id={{object.id}}&amp;model=helpdesk.ticket&amp;view_type=form">Ver Detalles del Ticket</a></p>
<p>Saludos,<br/>Sistema de Mesa de Ayuda</p>
        ]]></field>
    </record>
</data>
</odoo>
