<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_helpdesk_routing" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.helpdesk.routing</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="priority" eval="5"/>
            <field name="arch" type="xml">
                <!-- Agregar al final del formulario -->
                <xpath expr="//form" position="inside">
                    <div class="app_settings_block" data-string="Enrutamiento Mesa de Ayuda" string="Enrutamiento Mesa de Ayuda" data-key="helpdesk_routing">
                        <h2>Enrutamiento de Mesa de Ayuda</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <div class="o_setting_right_pane">
                                        <div class="o_form_label">Asignación de Equipos</div>
                                        <div class="text-muted">
                                            Configurar asignaciones de equipos internos y externos
                                        </div>
                                        <div class="content-group">
                                            <div class="mt16">
                                                <label for="internal_domains" string="Dominios Internos" class="o_light_label"/>
                                                <field name="internal_domains" placeholder="wavext.io,empresa.com"/>
                                            </div>
                                            <div class="mt16">
                                                <label for="internal_team_id" string="Equipo Interno" class="o_light_label"/>
                                                <field name="internal_team_id"/>
                                            </div>
                                            <div class="mt16">
                                                <label for="external_team_id" string="Equipo Externo" class="o_light_label"/>
                                                <field name="external_team_id"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
